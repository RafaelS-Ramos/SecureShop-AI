<!DOCTYPE html>
<html lang="pt-BR">

<head>

<meta charset="UTF-8">

<meta name="viewport"
content="width=device-width, initial-scale=1">

<title>Assistente IA</title>

<link
href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
rel="stylesheet">

</head>

<body class="bg-light">

<nav class="navbar navbar-dark bg-dark">

<div class="container">

<a class="navbar-brand"
href="/">

SecureShop AI

</a>

<a
href="/"
class="btn btn-secondary">

← Loja

</a>

</div>

</nav>

<div class="container mt-5">

<div class="card shadow">

<div class="card-body">

<h2 class="mb-4">

Assistente Inteligente com RAG

</h2>

<form
action="/ai/ask"
method="POST">

<div class="mb-3">

<textarea
class="form-control"
rows="4"
name="question"
placeholder="Ex.: Preciso de um notebook para programação."
required><%= question %></textarea>

</div>

<button
class="btn btn-primary">

Perguntar

</button>

</form>

<% if(products.length>0){ %>

<hr>

<h4>

Produtos recuperados pelo RAG

</h4>

<div class="row">

<% products.forEach(product=>{ %>

<div class="col-md-4">

<div class="card mb-3">

<div class="card-body">

<h5>

<%= product.name %>

</h5>

<p>

<%= product.category %>

</p>

<strong>

R$

<%= Number(product.price).toFixed(2) %>

</strong>

</div>

</div>

</div>

<% }) %>

</div>

<% } %>

<% if(answer){ %>

<hr>

<h4>

Resposta da IA

</h4>

<div class="alert alert-success">

<%= answer %>

</div>

<% } %>

</div>

</div>

</div>

</body>

</html>