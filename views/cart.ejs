<!DOCTYPE html>
<html>

<head>

<meta charset="UTF-8">

<title>Carrinho</title>

<link rel="stylesheet" href="/style.css">

</head>

<body>

<h1>Meu Carrinho</h1>

<% if(products.length===0){ %>

<p>Carrinho vazio.</p>

<% } else { %>

<table border="1" cellpadding="8">

<tr>

<th>Produto</th>

<th>Qtd</th>

<th>Preço</th>

<th>Subtotal</th>

<th></th>

</tr>

<% products.forEach(product=>{ %>

<tr>

<td><%= product.name %></td>

<td><%= product.quantity %></td>

<td>R$ <%= Number(product.price).toFixed(2) %></td>

<td>R$ <%= Number(product.subtotal).toFixed(2) %></td>

<td>

<form
action="/cart/remove/<%= product.id %>"
method="POST">

<button>

Remover

</button>

</form>

</td>

</tr>

<% }) %>

</table>

<h2>

Total:

R$ <%= Number(total).toFixed(2) %>

</h2>

<form action="/cart/clear" method="POST">

<button>

Limpar Carrinho

</button>

</form>

<% } %>

<br>

<a href="/">Voltar à loja</a>

</body>

</html>