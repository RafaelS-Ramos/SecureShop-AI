<!DOCTYPE html>
<html lang="pt-BR">

<head>

<meta charset="UTF-8">

<meta name="viewport"
      content="width=device-width, initial-scale=1">

<title>Minha Conta</title>

<link
href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
rel="stylesheet">

</head>

<body class="bg-light">

<nav class="navbar navbar-dark bg-dark">

<div class="container">

<a class="navbar-brand"
href="/">

SecureShop AI

</a>

<a
href="/logout"
class="btn btn-danger">

Sair

</a>

</div>

</nav>

<div class="container mt-5">

<div class="row justify-content-center">

<div class="col-lg-8">

<div class="card shadow">

<div class="card-header bg-primary text-white">

<h3 class="mb-0">

Minha Conta

</h3>

</div>

<div class="card-body">

<div class="row">

<div class="col-md-6">

<h5>Nome</h5>

<p>

<%= user.name %>

</p>

</div>

<div class="col-md-6">

<h5>E-mail</h5>

<p>

<%= user.email %>

</p>

</div>

</div>

<hr>

<div class="row">

<div class="col-md-6">

<h5>Perfil</h5>

<span class="badge bg-success">

<%= user.role %>

</span>

</div>

<div class="col-md-6">

<h5>Status</h5>

<span class="badge bg-primary">

Autenticado

</span>

</div>

</div>

<hr>

<div class="d-grid gap-2">

<a
href="/cart"
class="btn btn-primary">

Meu Carrinho

</a>

<a
href="/ai"
class="btn btn-info">

Assistente Inteligente

</a>

<% if(user.role==="ADMIN"){ %>

<a
href="/admin"
class="btn btn-warning">

⚙ Painel Administrativo

</a>

<% } %>

<a
href="/"
class="btn btn-outline-secondary">

← Voltar à Loja

</a>

</div>

</div>

</div>

</div>

</div>

</div>

</body>

</html>