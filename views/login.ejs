<!DOCTYPE html>
<html lang="pt-BR">

<head>

    <meta charset="UTF-8">

    <meta name="viewport"
          content="width=device-width, initial-scale=1">

    <title>Login - SecureShop AI</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          rel="stylesheet">

</head>

<body class="bg-light">

<div class="container">

    <div class="row justify-content-center mt-5">

        <div class="col-md-5">

            <div class="card shadow">

                <div class="card-body p-4">

                    <h2 class="text-center mb-4">

                        Login

                    </h2>

                    <% if(error){ %>

                        <div class="alert alert-danger">

                            <%= error %>

                        </div>

                    <% } %>

                    <form action="/login"
                          method="POST">

                        <div class="mb-3">

                            <label class="form-label">

                                E-mail

                            </label>

                            <input
                                type="email"
                                name="email"
                                class="form-control"
                                required>

                        </div>

                        <div class="mb-4">

                            <label class="form-label">

                                Senha

                            </label>

                            <input
                                type="password"
                                name="password"
                                class="form-control"
                                required>

                        </div>

                        <button
                            class="btn btn-primary w-100">

                            Entrar

                        </button>

                    </form>

                    <hr>

                    <p class="text-center">

                        Ainda não possui conta?

                    </p>

                    <a
                        href="/register"
                        class="btn btn-outline-success w-100">

                        Criar Conta

                    </a>

                    <a
                        href="/"
                        class="btn btn-link w-100 mt-3">

                        ← Voltar para a loja

                    </a>

                </div>

            </div>

        </div>

    </div>

</div>

</body>

</html>