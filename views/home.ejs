<!DOCTYPE html>
<html lang="pt-BR">

<head>

    <meta charset="UTF-8">

    <meta name="viewport"
          content="width=device-width, initial-scale=1">

    <title>SecureShop AI</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          rel="stylesheet">

    <link rel="stylesheet"
          href="/style.css">

</head>

<body class="bg-light">

<!-- NAVBAR -->

<nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow">

    <div class="container">

        <a class="navbar-brand fw-bold"
           href="/">

            🛒 SecureShop AI

        </a>

        <button class="navbar-toggler"
                data-bs-toggle="collapse"
                data-bs-target="#navbar">

            <span class="navbar-toggler-icon"></span>

        </button>

        <div class="collapse navbar-collapse"
             id="navbar">

            <ul class="navbar-nav ms-auto">

                <li class="nav-item">
                    <a class="nav-link"
                       href="/">Home</a>
                </li>

                <% if(user){ %>

                    <li class="nav-item">
                        <a class="nav-link"
                           href="/account">Minha Conta</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link"
                           href="/cart">Carrinho</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link"
                           href="/ai">
                            Assistente IA
                        </a>
                    </li>

                    <% if(user.role==="ADMIN"){ %>

                        <li class="nav-item">
                            <a class="nav-link"
                               href="/admin">
                                Administração
                            </a>
                        </li>

                    <% } %>

                    <li class="nav-item">

                        <a class="btn btn-danger ms-2"
                           href="/logout">

                            Sair

                        </a>

                    </li>

                <% } else { %>

                    <li class="nav-item">

                        <a class="btn btn-outline-light me-2"
                           href="/login">

                            Login

                        </a>

                    </li>

                    <li class="nav-item">

                        <a class="btn btn-primary"
                           href="/register">

                            Cadastro

                        </a>

                    </li>

                <% } %>

            </ul>

        </div>

    </div>

</nav>

<!-- HERO -->

<section class="py-5 bg-white border-bottom">

    <div class="container text-center">

        <h1 class="display-5 fw-bold">

            SecureShop AI

        </h1>

        <p class="lead">

            E-commerce desenvolvido com Node.js, Express,
            SQLite e Inteligência Artificial utilizando
            Retrieval-Augmented Generation (RAG) com Ollama.

        </p>

    </div>

</section>

<!-- PRODUTOS -->

<div class="container py-5">

    <div class="row">

        <% if(products.length===0){ %>

            <div class="col-12">

                <div class="alert alert-warning">

                    Nenhum produto cadastrado.

                </div>

            </div>

        <% } %>

        <% products.forEach(product=>{ %>

            <div class="col-lg-4 col-md-6 mb-4">

                <div class="card shadow-sm h-100">

                    <div class="card-body d-flex flex-column">

                        <h4 class="card-title">

                            <%= product.name %>

                        </h4>

                        <p class="card-text">

                            <%= product.description %>

                        </p>

                        <p>

                            <span class="badge bg-secondary">

                                <%= product.category %>

                            </span>

                        </p>

                        <p class="mb-1">

                            <strong>Estoque:</strong>

                            <%= product.stock %>

                        </p>

                        <h3 class="text-success mt-2">

                            R$
                            <%= Number(product.price).toFixed(2) %>

                        </h3>

                        <div class="mt-auto">

                            <% if(user){ %>

                                <form action="/cart/add/<%= product.id %>"
                                      method="POST">

                                    <button class="btn btn-primary w-100">

                                        Adicionar ao Carrinho

                                    </button>

                                </form>

                            <% } else { %>

                                <a href="/login"
                                   class="btn btn-outline-primary w-100">

                                    Faça login para comprar

                                </a>

                            <% } %>

                        </div>

                    </div>

                </div>

            </div>

        <% }) %>

    </div>

</div>

<footer class="bg-dark text-white py-4">

    <div class="container text-center">

        <p class="mb-0">

            SecureShop AI • Projeto Acadêmico

        </p>

        <small>

            Node.js • Express • SQLite • Ollama • RAG • Embeddings

        </small>

    </div>

</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>

</html>